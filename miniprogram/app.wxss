page {
  min-height: 100vh;
  background: #111;
  color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
}

.muted {
  color: #a3a3a3;
}

.panel {
  border: 1rpx solid #2f2f2f;
  border-radius: 12rpx;
  background: #171717;
}

.button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 10rpx;
  background: #16a34a;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

.empty {
  padding: 32rpx 24rpx;
  color: #a3a3a3;
  font-size: 26rpx;
}
