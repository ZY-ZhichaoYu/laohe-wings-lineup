.home-page {
  padding-bottom: 40rpx;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #22c55e;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.title {
  margin-top: 6rpx;
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 8rpx;
  color: #d4d4d4;
  font-size: 26rpx;
}

.mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border: 2rpx solid #22c55e;
  border-radius: 50%;
  color: #bbf7d0;
  font-size: 30rpx;
  font-weight: 900;
  background: #0f1f16;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.stat {
  padding: 18rpx 12rpx;
  text-align: center;
}

.stat-num {
  display: block;
  color: #facc15;
  font-size: 34rpx;
  font-weight: 900;
}

.stat-label {
  display: block;
  margin-top: 4rpx;
  color: #a3a3a3;
  font-size: 22rpx;
}

.section-title {
  margin: 26rpx 0 12rpx;
  color: #f5f5f5;
  font-size: 30rpx;
  font-weight: 900;
}

.player-list {
  display: grid;
  gap: 12rpx;
}

.player-row {
  display: grid;
  grid-template-columns: 108rpx 1fr;
  align-items: center;
  padding: 18rpx;
}

.num {
  color: #93c5fd;
  font-size: 30rpx;
  font-weight: 900;
}

.name {
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

.bench-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.bench-card {
  min-height: 110rpx;
  padding: 18rpx;
}

.bench-num {
  color: #93c5fd;
  font-size: 24rpx;
  font-weight: 900;
}

.bench-name {
  margin-top: 6rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
}
