.title {
  margin-bottom: 24rpx;
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
}

.info {
  padding: 8rpx 20rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #2f2f2f;
  font-size: 26rpx;
}

.row:last-child {
  border-bottom: 0;
}

.label {
  color: #a3a3a3;
}

.value {
  color: #f5f5f5;
  font-weight: 800;
}

.section-title {
  margin: 28rpx 0 12rpx;
  color: #f5f5f5;
  font-size: 30rpx;
  font-weight: 900;
}

.list {
  display: grid;
  gap: 14rpx;
  padding: 22rpx;
  color: #d4d4d4;
  font-size: 26rpx;
}
